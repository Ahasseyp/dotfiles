# Machine-specific ssh hosts
# Copy this file to ~/.ssh/config.local and fill in values for the current machine.

Host *.pgn.sh
  ProxyCommand /opt/homebrew/bin/cloudflared access ssh --loglevel debug --hostname %h

Host github.com
  IdentityFile ~/.ssh/id_paragon
  IdentitiesOnly yes

Host personalgit
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

# --Bastion Host List (Auto-Generated) --
Host aidentified appsmith boosted brevian bugherd buildertrend colab copyai crewai dragos fintrx five9-nonprod ismsonline-ap ismsonline-eu ismsonline-uk ismsonline-us jasper josef meisterplan mileiq nuwacom observeai observeai-eu observeai-us enterprise-staging openphone paragon-eu pipedrive-eu pipedrive-us postman-us sinch sosafe supper swoogo upsales xace
  ProxyCommand /opt/homebrew/bin/cloudflared access ssh --loglevel debug --hostname %h.pgn.sh
  User ubuntu
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  IdentityFile ~/.ssh/enterprise/%h.pub
  IdentitiesOnly yes
  StrictHostKeyChecking no
